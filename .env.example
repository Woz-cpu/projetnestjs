# ===========================================
# CONFIGURATION DE L'APPLICATION
# Copier ce fichier en .env et adapter les valeurs
# ===========================================

# Base de données PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app_db
DB_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/app_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6390

# Mail (Mailpit)
MAIL_HOST=localhost
MAIL_SMTP_PORT=1026
MAIL_WEB_PORT=8026

# Ports des services
BACKEND_PORT=3001
FRONTEND_PORT=5174
